# Copy to .env and fill in. Do not commit .env.

# LLM backend: gemini | ollama
PLANNER_LLM_BACKEND=gemini

# --- Gemini (recommended default for strong multimodal understanding) ---
GOOGLE_API_KEY=
# Optional alias:
# GEMINI_API_KEY=

# Model id (e.g. gemini-2.0-flash or a preview Flash-Lite id from AI Studio docs)
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# --- Ollama (local; good for privacy / offline iteration) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llava-phi3:3.8b
