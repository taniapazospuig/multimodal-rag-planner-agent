# Copy to .env and fill in. Do not commit .env.

# LLM backend: gemini | ollama
PLANNER_LLM_BACKEND=gemini

# Gemini
GOOGLE_API_KEY=

# Model id
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Ollama (local; good for privacy / offline iteration)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llava-phi3:3.8b

# Ablation mode: text_only | text_retrieval_mllm | multimodal_retrieval_mllm
PLANNER_RAG_MODE=text_retrieval_mllm

# OpenCLIP backbone (shared by image and text retrievers)
OPEN_CLIP_MODEL=ViT-B-32
OPEN_CLIP_PRETRAINED=laion2b_s34b_b79k

# Hybrid text retrieval index settings
TEXT_COLLECTION_NAME=text_chunks
TEXT_BM25_PATH=data/kb/02_index/bm25_corpus.jsonl
TEXT_CONTEXT_MODE=metadata
TEXT_DENSE_K=12
TEXT_BM25_K=12
TEXT_HYBRID_K=6
TEXT_RRF_K=60

# Weighted RRF fusion for multimodal context selection
# 1.0 -> text-only preference, 0.0 -> image-only preference
MULTIMODAL_FUSION_ALPHA=0.7
MULTIMODAL_FUSION_K=8
